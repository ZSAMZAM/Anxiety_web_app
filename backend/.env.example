DEVELOPMENT_OTP_MODE=true
# OTP_DELIVERY_WEBHOOK_URL=https://your-sms-provider.example/send-otp

# Hormuud merchant payment integration.
# Keep real credentials only in backend/.env, never in source control.
HORMUUD_MERCHANT_API_URL=https://api.waafipay.net/asm
HORMUUD_MERCHANT_STATUS_URL=https://api.waafipay.net/asm
HORMUUD_MERCHANT_UID=your-merchant-uid
HORMUUD_MERCHANT_ID=your-merchant-uid
HORMUUD_API_USER_ID=your-api-user-id
HORMUUD_MERCHANT_API_KEY=your-api-key
HORMUUD_CHANNEL_NAME=WEB
HORMUUD_SERVICE_NAME=API_PURCHASE
HORMUUD_STATUS_SERVICE_NAME=API_GET_TRANSACTION_INFO
HORMUUD_PAYMENT_METHOD=mwallet_account
