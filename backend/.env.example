JWT_SECRET=change-me
DB_HOST=your-cloud-mysql-host
DB_PORT=3306
DB_NAME=anxiety_prediction
DB_USER=your-cloud-mysql-user
DB_PASSWORD=your-cloud-mysql-password
SUPER_ADMIN_DB_NAME=super_admins
SUPER_ADMIN_TABLE=super_admins
FLASK_DEBUG=0
FLASK_ENV=production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://your-web-frontend.onrender.com,https://your-super-admin.onrender.com
MAX_UPLOAD_BYTES=5242880
UPLOAD_DIR=/var/data/anxietycare/uploads
ENABLE_HSTS=1

# Optional integrations
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta2
GEMINI_MODEL_NAME=models/text-bison-001
HORMUUD_MERCHANT_API_URL=
HORMUUD_MERCHANT_STATUS_URL=
HORMUUD_MERCHANT_API_KEY=
HORMUUD_MERCHANT_ID=
HORMUUD_MERCHANT_UID=
HORMUUD_API_USER_ID=
HORMUUD_CHANNEL_NAME=WEB
HORMUUD_SERVICE_NAME=API_PURCHASE
HORMUUD_PAYMENT_METHOD=mwallet_account
TABAARAK_SMS_USERNAME=
TABAARAK_SMS_PASSWORD=
TABAARAK_SMS_SENDER_ID=AnxietyCare
